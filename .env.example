# Copy to .env and fill in real values.
# Local dev: run `docker compose up -d` then use:
DATABASE_URL="mysql://weapp:weapp_dev@127.0.0.1:3306/we_project"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Editor image storage: supabase (default) or cloudinary
# IMAGE_STORAGE="supabase"

# Supabase Storage (default). Create a public bucket (default name editor-images) so getPublicUrl works for <img src>.
# Server uploads use the service role key only in API routes.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"
SUPABASE_STORAGE_BUCKET="editor-images"

# Optional Cloudinary uploads. Set IMAGE_STORAGE to cloudinary to use this instead of Supabase.
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Anthropic Claude (note AI tools). Server-side only.
ANTHROPIC_API_KEY="sk-ant-api03-..."
# Optional override, default claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Liveblocks (realtime cursors + collaborative TipTap). Secret from dashboard API keys.
LIVEBLOCKS_SECRET_KEY="sk_live_..."
# Set to true so the app wraps the note editor in Liveblocks and enables /share live pages.
NEXT_PUBLIC_LIVEBLOCKS_ENABLED="true"

# Soft storage quota for dashboard progress bar (megabytes)
NEXT_PUBLIC_STORAGE_QUOTA_MB="100"
